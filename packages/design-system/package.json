{
  "name": "design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens/tokens.css",
    "./hydration.css": "./src/styles/hydration.css"
  },
  "files": [
    "dist",
    "src/tokens",
    "src/styles"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "analyze": "cem analyze --globs \"src/components/**/*.ts\" --outdir .storybook",
    "storybook": "pnpm run analyze && storybook dev -p 6006",
    "build-storybook": "pnpm run analyze && storybook build"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/js": "^10.0.1",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/web-components": "^10.4.6",
    "@storybook/web-components-vite": "^10.4.6",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "catalog:",
    "storybook": "^10.4.6",
    "typescript": "catalog:",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3"
  },
  "customElements": ".storybook/custom-elements.json"
}
