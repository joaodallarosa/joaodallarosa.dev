# Nuxt Studio (see docs/studio-setup.md for how to obtain these).
# Flat, unprefixed names -- read directly via process.env inside the nuxt-studio module,
# not mapped through Nuxt's NUXT_-prefixed runtimeConfig convention. Do not add a NUXT_ prefix.

# Google OAuth client (login to /_studio) -- Google Cloud Console > APIs & Services > Credentials
STUDIO_GOOGLE_CLIENT_ID=
STUDIO_GOOGLE_CLIENT_SECRET=

# Comma-separated allowlist of Google account emails permitted to edit
STUDIO_GOOGLE_MODERATORS=

# GitHub fine-grained personal access token, scoped to this repo with Contents: Read and write
STUDIO_GITHUB_TOKEN=
